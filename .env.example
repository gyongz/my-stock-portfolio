# Supabase PostgreSQL connection string. Use the transaction pooler URL in deployments.
DATABASE_URL=postgresql://postgres.project:password@host:6543/postgres?sslmode=require

# Browser-safe Supabase settings. Never put the service_role key in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
